FROM jenkins/jenkins:lts

USER root

# Install prerequisites
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    jq \
    bc \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# Install virtualenv via pip
RUN pip3 install virtualenv --break-system-packages

USER jenkins
